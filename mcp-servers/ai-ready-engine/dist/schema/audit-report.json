{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Ready Audit Report",
  "type": "object",
  "required": ["auditLevel", "overallScore", "passRate"],
  "properties": {
    "auditLevel": { "type": "string", "enum": ["C", "B", "A", "all"] },
    "overallScore": { "type": "number", "minimum": 0, "maximum": 1 },
    "passRate": { "type": "number", "minimum": 0, "maximum": 1 },
    "total": { "type": "integer" },
    "passed": { "type": "integer" },
    "failed": { "type": "integer" },
    "aiReadyLevel": { "type": "string", "enum": ["L0", "L1", "L2", "L3"] },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "severity": { "type": "string", "enum": ["high", "medium", "low", "none"] },
          "detail": { "type": "string" }
        }
      }
    },
    "details": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "passed": { "type": "boolean" },
          "severity": { "type": "string" }
        }
      }
    },
    "recommendation": { "type": "string" }
  }
}
